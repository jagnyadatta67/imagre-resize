# ── Azure Blob Storage ────────────────────────────────────────
AZURE_ACCOUNT_NAME=your_storage_account_name
AZURE_ACCOUNT_KEY=your_storage_account_key
SOURCE_BLOB_PREFIX=lifestyle/
TARGET_CONTAINER=lifestyle-newc
FALLBACK_CONTAINER=in-media

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=image_pipeline
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# ── Google Vision (path to service account JSON) ──────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Image output ──────────────────────────────────────────────
TARGET_W=1450
TARGET_H=2100
JPEG_QUALITY=90
TEXT_THRESHOLD=40

# ── Pipeline behaviour ────────────────────────────────────────
BULK_WORKERS=10
FULL_AI=false

